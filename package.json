{
  "name": "artiada",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "media": "node scripts/sync-media.mjs",
    "images": "node scripts/sync-media.mjs",
    "news:export": "tsx scripts/sync-news-json.mjs",
